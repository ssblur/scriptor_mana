{
	"schemaVersion": 1,
	"id": "scriptor_mana",
	"version": "${version}",
	"name": "Scriptor Magicae: Mana Mode",
	"description": "An addon for Scriptor that replaces the default cooldown system with a mana bar.",
	"authors": [ "SSBlur" ],
	"contact": {
		"homepage": "https://github.com/ssblur/scriptor_mana",
		"sources": "https://github.com/ssblur/scriptor_mana"
	},
	"license": "CC0-1.0",
	"icon": "assets/scriptor_mana/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.ssblur.scriptor_mana.fabric.ScriptorManaFabric"
		],
		"client": [
			"com.ssblur.scriptor_mana.fabric.ScriptorManaFabric"
		]
	},
	"mixins": [
		"scriptor_mana.mixins.json"
	],
	"depends": {
		"fabricloader": ">=${fabric_loader_version}",
		"minecraft": ">=${minecraft_version}",
		"java": ">=21",
